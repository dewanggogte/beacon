{
  "name": "Buffett Checklist",
  "version": "1.0.0",
  "description": "10 criteria based on Warren Buffett's investment principles — durable competitive advantages, consistent earnings, low debt",
  "criteria": [
    {
      "id": "roe_consistency",
      "name": "ROE Consistency",
      "description": "ROE >= 15% for 8+ of last 10 years",
      "threshold": "8 of 10 years >= 15%",
      "weight": 12
    },
    {
      "id": "roe_level",
      "name": "ROE Level",
      "description": "10-year average ROE >= 20%",
      "threshold": "10yr avg >= 20%",
      "weight": 12
    },
    {
      "id": "opm_stability",
      "name": "Operating Margin Stability",
      "description": "Average OPM >= 15% and not declining trend",
      "threshold": "avg >= 15%, not declining",
      "weight": 10
    },
    {
      "id": "net_margin",
      "name": "Net Margin Level",
      "description": "5-year average net margin >= 15%",
      "threshold": "5yr avg >= 15%",
      "weight": 8
    },
    {
      "id": "low_debt",
      "name": "Low Debt",
      "description": "Debt-to-equity ratio < 0.80",
      "threshold": "D/E < 0.80",
      "weight": 12
    },
    {
      "id": "capex_efficiency",
      "name": "CapEx Efficiency",
      "description": "CapEx proxy / Net Profit < 50% average (relaxed from 25% due to proxy)",
      "threshold": "capex/profit < 50%",
      "weight": 8
    },
    {
      "id": "owner_earnings",
      "name": "Owner Earnings",
      "description": "Positive and growing (3-year trend)",
      "threshold": "positive + growing 3yr",
      "weight": 10
    },
    {
      "id": "revenue_consistency",
      "name": "Revenue Growth Consistency",
      "description": "Revenue grew YoY in 8+ of last 10 years",
      "threshold": "8 of 10 years grew",
      "weight": 10
    },
    {
      "id": "interest_to_revenue",
      "name": "Interest to Revenue",
      "description": "Interest expense < 15% of revenue",
      "threshold": "< 15%",
      "weight": 8
    },
    {
      "id": "promoter_alignment",
      "name": "Promoter Alignment",
      "description": "Promoter holding > 40%, stable or increasing",
      "threshold": "> 40%, stable/increasing",
      "weight": 10
    }
  ]
}
